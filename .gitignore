# =============================================================================
# MACRO Solutions Tools — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.p12
*.pfx

# -----------------------------------------------------------------------------
# Node / Frontend
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
.yarn/
dist/
build/
.vite/
*.local

# -----------------------------------------------------------------------------
# PHP / Laravel Backend
# -----------------------------------------------------------------------------
vendor/
bootstrap/cache/*.php
storage/app/public
storage/logs/*.log
storage/framework/cache/
storage/framework/sessions/
storage/framework/views/
*.sqlite
*.sqlite-journal
database/*.sqlite
.phpunit.result.cache
phpunit.xml

# -----------------------------------------------------------------------------
# OS Specific
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encdata
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# -----------------------------------------------------------------------------
# VS Code
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
*.vsix

# -----------------------------------------------------------------------------
# GitHub Copilot / AI Extensions
# -----------------------------------------------------------------------------
.copilot/
.github/copilot/
.copilot-cache/
.ai-cache/
*.copilot.json
.codeium/
.tabnine/
.kite/
.continue/
.aider*
.cursor/

# -----------------------------------------------------------------------------
# Logs & Temp Files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.swp
*.swo
*.bak
*.orig
.cache/
tmp/
temp/

# -----------------------------------------------------------------------------
# Package Manager Lock Files (optional — remove if you want to commit them)
# -----------------------------------------------------------------------------
# package-lock.json
# yarn.lock
# composer.lock

# -----------------------------------------------------------------------------
# IDE / Editor (general)
# -----------------------------------------------------------------------------
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
nbproject/

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
/tests/coverage/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.zip
*.tar.gz
*.rar
requirements/php-8.5.1-src/
